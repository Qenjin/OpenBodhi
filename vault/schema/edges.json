{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/Qenjin/OpenBodhi/blob/main/vault/schema/edges.json",
  "title": "OpenBodhi Edge",
  "description": "A directed relationship between two nodes in the OpenBodhi vault",
  "type": "object",
  "required": ["id", "type", "from", "to", "created_at", "created_by"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID v4. Generated on creation."
    },
    "type": {
      "type": "string",
      "enum": ["LEADS_TO", "GENERATES", "SURFACES_FROM", "CONTRADICTS", "ASSOCIATED_WITH", "INFORMS"],
      "description": "Relationship type. See docs/ontology.md for semantics."
    },
    "from": {
      "type": "string",
      "format": "uuid",
      "description": "Source node UUID."
    },
    "to": {
      "type": "string",
      "format": "uuid",
      "description": "Target node UUID."
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp with timezone."
    },
    "created_by": {
      "type": "string",
      "enum": ["curator", "distiller", "janitor", "surveyor", "human"],
      "description": "Which worker or human created this edge."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Confidence score for AI-generated edges. Human edges default to 1.0."
    },
    "note": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional human or AI annotation explaining why this edge exists."
    }
  }
}
