# OpenBodhi Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to git

# Required: Anthropic API key
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-key-here

# Optional: Ollama host (for local embeddings + local model)
# Leave default if running Ollama on same machine
OLLAMA_HOST=http://localhost:11434

# Vault path (where your knowledge graph is stored)
# Default is ./vault relative to project root
BODHI_VAULT_PATH=./vault

# Morning digest delivery time (24h format, local timezone)
BODHI_DIGEST_TIME=06:00

# Optional: Signal phone number used for the bridge
# Format: +1XXXXXXXXXX
BODHI_SIGNAL_NUMBER=

# Optional: Override default model (defaults to claude-opus-4-6)
BODHI_PRIMARY_MODEL=claude-opus-4-6
BODHI_FAST_MODEL=claude-sonnet-4-6
